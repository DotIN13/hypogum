# ── Agent / MCP → db service ───────────────
HYPOGUM_DB_URL=http://localhost:8055        # URL of the `hypogum db` service the agent/MCP connect to

# ── `hypogum db` service backend ───────────
HYPOGUM_DB_HOST=0.0.0.0                       # bind host for `hypogum db`
HYPOGUM_DB_PORT=8055                          # bind port for `hypogum db`
HYPOGUM_DB_DSN=sqlite+aiosqlite:///./data/app.db   # relational DSN: local sqlite | remote postgres/mysql
HYPOGUM_DATA_DIR=./data

# ── Memory ─────────────────────────────────
HYPOGUM_MEMORY_DIR=./data/memory             # local markdown memory directory (agent/MCP read/write directly)
HYPOGUM_AGENT_COMMAND=opencode               # agent CLI for memory ingest/lint tasks
HYPOGUM_AGENT_ARGS=run                        # subcommand (not used when --attach mode)
HYPOGUM_AGENT_FLAGS=--format json
HYPOGUM_AGENT_TIMEOUT=1800                     # seconds per agent task (ingest + tips)
HYPOGUM_AGENT_SERVE_PORT=4099                # port for `opencode serve` (started by dev.py)
HYPOGUM_AGENT_SERVE_HOST=127.0.0.1

# ── LLM provider ───────────────────────────
HYPOGUM_LLM_PROVIDER=gemini                 # gemini | openai | anthropic
HYPOGUM_LLM_MODEL=gemini-3.1-flash-lite
GOOGLE_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── Auth (for store server) ────────────────
HYPOGUM_AUTH_PROVIDER=noauth                # noauth | jwt | oauth2
HYPOGUM_AUTH_JWT_SECRET=
HYPOGUM_AUTH_JWT_ALGORITHM=ES256
HYPOGUM_AUTH_JWT_JWKS_URL=
HYPOGUM_AUTH_JWT_ISSUER=
HYPOGUM_AUTH_JWT_AUDIENCE=hypogum
HYPOGUM_AUTH_OAUTH2_INTROSPECTION_URL=
HYPOGUM_AUTH_OAUTH2_CLIENT_ID=
HYPOGUM_AUTH_OAUTH2_CLIENT_SECRET=
HYPOGUM_AUTH_OAUTH2_USER_CLAIM=sub
HYPOGUM_AUTH_OAUTH2_CACHE_TTL=300

# ── Agent ──────────────────────────────────
HYPOGUM_USER_ID=default
HYPOGUM_OBSERVE_SCREEN_ENABLED=true
HYPOGUM_OBSERVE_SCREEN_INTERVAL=60
HYPOGUM_OBSERVE_CAMERA_ENABLED=false
HYPOGUM_OBSERVE_CAMERA_INTERVAL=120
HYPOGUM_OBSERVE_QUALITY=85
HYPOGUM_OBSERVE_MAX_WIDTH=1920
HYPOGUM_OBSERVE_DETECT_WINDOWS=true
HYPOGUM_SCREEN_DEDUP_ENABLED=true           # discard a screenshot too similar to the previous saved one
HYPOGUM_SCREEN_DEDUP_THRESHOLD=10           # max dHash Hamming distance treated as duplicate (0..hash_size^2)
HYPOGUM_SCREEN_DEDUP_HASH_SIZE=16           # dHash grid size; higher = more sensitive to small changes
HYPOGUM_PAUSE_WHEN_LOCKED=true              # pause observing/processing while workstation is locked
HYPOGUM_PAUSE_WHEN_IDLE=false              # pause once no user input for HYPOGUM_IDLE_THRESHOLD seconds
HYPOGUM_IDLE_THRESHOLD=300                  # idle seconds before pausing
HYPOGUM_NOTIFY_ON_TIPS=true
HYPOGUM_PROCESS_INTERVAL=900                # seconds between processing cycles (describe → ingest → tips inline)
HYPOGUM_MEMORY_LINT_INTERVAL=86400          # seconds between lint cycles (default: daily)

# ── Calendar / user input ──────────────────
HYPOGUM_TIMEZONE=                           # IANA name (e.g. America/Los_Angeles); blank = OS-local
HYPOGUM_OBSERVE_USER_INPUT_ENABLED=true     # ingest notes dropped in <memory>/.tasks/user-input/
HYPOGUM_USER_INPUT_INTERVAL=60              # seconds between user-input inbox polls
HYPOGUM_CALENDAR_ICS=false                  # auto-export data/calendar.ics after each ingest cycle
HYPOGUM_CALENDAR_VIEW=true                  # render memory/calendar_view.md (+ PNGs) after each ingest cycle
HYPOGUM_CALENDAR_VIEW_PNG=true              # also render calendar_view_{day,week,month}.png (matplotlib, installed by default)
